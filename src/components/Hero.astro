---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import heroImage1 from "../assets/mocks/m1.png";
import heroImage2 from "../assets/mocks/m2.png";
import heroImage3 from "../assets/mocks/m3.png";
import heroImage4 from "../assets/mocks/m4.png";
import heroImage5 from "../assets/mocks/m5.png";
import heroImage6 from "../assets/mocks/m6.png";

// Array de videos para la galería
const videos = [
  {
    src: "/turnapp-promo-2.mp4",
    alt: "Demo de TurnApp - Sistema de Gestión de Turnos",
    duration: 35000,
  },
];

// Array de imágenes para la galería
const images = [
  { src: heroImage1, alt: "Panel de Control TurnApp - Vista 1" },
  { src: heroImage2, alt: "Panel de Control TurnApp - Vista 2" },
  { src: heroImage3, alt: "Panel de Control TurnApp - Vista 3" },
  { src: heroImage4, alt: "Panel de Control TurnApp - Vista 4" },
  { src: heroImage5, alt: "Panel de Control TurnApp - Vista 5" },
  { src: heroImage6, alt: "Panel de Control TurnApp - Vista 5" },
];
---

<section class="pt-20 pb-16 md:pt-28 md:pb-24 overflow-hidden relative flex flex-col items-center text-center">
  <!-- Subtle background pattern with parallax effect -->
  <div class="absolute inset-0 opacity-5 parallax" data-speed="0.1">
    <div
      class="absolute inset-0 bg-repeat"
      style="background-image: url('/grid-pattern.svg');"
    >
    </div>
  </div>

  <div class="container-custom relative z-10 flex flex-col items-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-payflo-blue/10 text-payflo-blue font-medium text-sm mb-8 animate-on-scroll delay-0 border border-payflo-blue/20">
      <Icon name="ph:lightning-duotone" class="w-4 h-4" />
      <span>El control absoluto de tu flujo de atención</span>
    </div>

    <h1
      class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold tracking-tight leading-[1.05] text-payflo-dark max-w-5xl flex flex-wrap justify-center gap-x-4"
    >
      <span class="animate-on-scroll delay-1 inline-block">Conoce</span>
      <span class="animate-on-scroll delay-2 inline-block text-transparent bg-clip-text bg-gradient-to-r from-payflo-purple to-payflo-blue">TurnApp</span>
    </h1>

    <p
      class="animate-on-scroll delay-3 mt-8 text-xl md:text-2xl text-gray-500 max-w-3xl leading-relaxed font-light"
    >
      El <span class="font-medium text-payflo-dark">Sistema de Turnos</span> centralizado y en tiempo real. 
      Su aliado definitivo para una atención al usuario eficiente y organizada. ¡Dígale adiós al caos en las filas!
    </p>
    
    <div
      class="animate-on-scroll delay-4 mt-12 flex flex-col sm:flex-row gap-5"
    >
      <a href="/book-demo" class="btn btn-primary shadow-lg shadow-payflo-purple/20 flex items-center justify-center gap-2 group relative overflow-hidden btn-magnetic px-8 py-4 text-lg">
        Agendar llamada
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="/product" class="btn btn-secondary flex items-center justify-center gap-2 btn-magnetic px-8 py-4 text-lg">
        Conoce más
      </a>
    </div>

    <!-- Social Proof Avatar Group -->
    <div class="animate-on-scroll delay-5 mt-10 flex items-center space-x-4">
      <div class="flex -space-x-3" role="img" aria-label="Customer testimonial avatars">
        <img src="/testimonial-avatar-1.jpg" alt="Sarah from TechCorp" class="w-12 h-12 rounded-full border-2 border-white shadow-md z-30 relative" />
        <img src="/testimonial-avatar-2.jpg" alt="Michael from DataFlow" class="w-12 h-12 rounded-full border-2 border-white shadow-md z-20 relative" />
        <img src="/testimonial-avatar-3.jpg" alt="Emma from CloudSuite" class="w-12 h-12 rounded-full border-2 border-white shadow-md z-10 relative" />
      </div>
      <div class="text-left">
        <div class="flex items-center text-yellow-400 text-sm">
          <Icon name="ph:star-duotone" class="w-4 h-4" />
          <Icon name="ph:star-duotone" class="w-4 h-4" />
          <Icon name="ph:star-duotone" class="w-4 h-4" />
          <Icon name="ph:star-duotone" class="w-4 h-4" />
          <Icon name="ph:star-duotone" class="w-4 h-4" />
        </div>
        <div class="text-sm font-medium text-gray-700 mt-0.5">
          Innovando los servicios de atención.
        </div>
      </div>
    </div>
  </div>

  <!-- SHOWCASE GALLERY (GLASSMORPHISM) -->
  <div class="mt-20 w-full max-w-[1400px] mx-auto px-4 md:px-8 animate-on-scroll delay-6 relative z-10">
    <div class="relative rounded-2xl md:rounded-[2rem] bg-gradient-to-b from-gray-50 to-gray-200/50 p-2 md:p-4 shadow-[0_40px_80px_-20px_rgba(0,0,0,0.15)] border border-white/50 backdrop-blur-xl">
      <div class="absolute inset-0 bg-gradient-to-tr from-payflo-purple/30 to-payflo-blue/30 blur-3xl opacity-40 -z-10 rounded-full scale-95 translate-y-10"></div>
      
      <div class="rounded-xl md:rounded-[1.5rem] overflow-hidden border border-gray-100/50 shadow-inner bg-black/5 relative group">
        <!-- Gallery Container -->
        <div class="image-gallery relative w-full aspect-[16/10] max-w-full">
          <!-- Videos -->
          {
            videos.map((video, index) => (
              <div
                class={`gallery-item absolute inset-0 transition-opacity duration-1000 ease-in-out ${
                  index === 0 ? "opacity-100" : "opacity-0"
                }`}
                data-active={index === 0 ? "true" : "false"}
                data-type="video"
                data-duration={video.duration}
              >
                <div class="relative w-full h-full bg-black/10">
                  <video
                    class="w-full h-full object-cover rounded-xl md:rounded-[1.5rem]"
                    preload="auto"
                    autoplay={index === 0}
                    muted
                    playsinline
                    loop={false}
                  >
                    <source src={video.src} type="video/mp4" />
                    Tu navegador no soporta el elemento de video.
                  </video>
                </div>
              </div>
            ))
          }

          <!-- Images -->
          {
            images.map((image, index) => (
              <div
                class="gallery-item absolute inset-0 opacity-0 transition-opacity duration-1000 ease-in-out"
                data-active="false"
                data-type="image"
                data-duration="5000"
              >
                <Image
                  src={image.src}
                  alt={image.alt}
                  class="w-full h-full object-cover rounded-xl md:rounded-[1.5rem]"
                />
              </div>
            ))
          }
          
          <!-- Modern Indicators -->
          <div class="absolute bottom-6 md:bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-10 bg-black/30 backdrop-blur-md px-4 py-3 rounded-full border border-white/20">
            {
              [...videos, ...images].map((_, idx) => (
                <div 
                  class={`gallery-dot h-2 rounded-full transition-all duration-500 ease-out ${idx === 0 ? 'bg-white w-8' : 'bg-white/40 w-2 hover:bg-white/60'}`}
                  data-index={idx}
                ></div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Estilos adicionales para la galería */
  .gallery-item {
    transition: opacity 1s ease-in-out;
  }

  .image-gallery {
    aspect-ratio: 16/10;
  }

  .image-gallery img,
  .image-gallery video {
    object-fit: cover;
    width: 100%;
    height: 100%;
  }
</style>

<script>
  const initImageGallery = (): (() => void) => {
    const gallery = document.querySelector<HTMLElement>(".image-gallery");
    if (!gallery) return () => {};

    const items = gallery.querySelectorAll<HTMLElement>(".gallery-item");
    let currentIndex: number = 0;
    let timeoutId: NodeJS.Timeout | null = null;

    const showNextItem = (): void => {
      const currentItem = items[currentIndex];
      currentItem.style.opacity = "0";
      currentItem.setAttribute("data-active", "false");

      const currentVideo = currentItem.querySelector<HTMLVideoElement>("video");
      if (currentVideo) {
        currentVideo.pause();
        currentVideo.currentTime = 0;
      }

      currentIndex = (currentIndex + 1) % items.length;

      const nextItem = items[currentIndex];
      nextItem.style.opacity = "1";
      nextItem.setAttribute("data-active", "true");

      const nextVideo = nextItem.querySelector<HTMLVideoElement>("video");
      if (nextVideo) {
        nextVideo.currentTime = 0;
        nextVideo.play().catch((error) => console.error("Error video:", error));
      }

      const durationAttr = nextItem.getAttribute("data-duration");
      const duration = durationAttr ? parseInt(durationAttr) : 5000;

      timeoutId = setTimeout(showNextItem, duration);

      const dots = gallery.querySelectorAll<HTMLElement>(".gallery-dot");
      dots.forEach((dot, idx) => {
        if (idx === currentIndex) {
          dot.classList.add("bg-white", "w-8");
          dot.classList.remove("bg-white/40", "w-2");
        } else {
          dot.classList.remove("bg-white", "w-8");
          dot.classList.add("bg-white/40", "w-2");
        }
      });
    };

    const startGallery = (): void => {
      if (timeoutId) clearTimeout(timeoutId);
      const initialDurationAttr = items[0].getAttribute("data-duration");
      const initialDuration = initialDurationAttr ? parseInt(initialDurationAttr) : 35000;
      timeoutId = setTimeout(showNextItem, initialDuration);
    };

    const video = items[0].querySelector<HTMLVideoElement>("video");
    if (video) {
      video.addEventListener("ended", () => showNextItem());
      video.addEventListener("error", () => {
        console.warn("Error cargando el video, continuando con imágenes...");
        setTimeout(showNextItem, 35000);
      });
      video.play().catch((error) => console.error("Error al reproducir el video inicial:", error));
    }

    startGallery();

    return (): void => {
      if (timeoutId) clearTimeout(timeoutId);
      items.forEach((item) => {
        const video = item.querySelector<HTMLVideoElement>("video");
        if (video) {
          video.pause();
          video.currentTime = 0;
        }
      });
    };
  };

  document.addEventListener("DOMContentLoaded", () => {
    initImageGallery();
  });

  document.addEventListener("astro:after-swap", () => {
    initImageGallery();
  });
</script>
