---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import featureImage1 from "../assets/features/ft1.webp";
import featureImage2 from "../assets/features/ft2.webp";
import featureImage3 from "../assets/features/ft3.webp";
import featureImage4 from "../assets/features/ft4.webp";
import featureImage5 from "../assets/features/ft5.webp";
import featureImage6 from "../assets/features/ft6.webp";

const features = [
  {
    title: "Monitoreo en Tiempo Real",
    description:
      "Visualice el estado de todas sus colas y módulos al instante desde un dashboard centralizado y dinámico.",
    icon: "ph:monitor-duotone",
    image: featureImage1,
  },
  {
    title: "Gestión Inteligente de Colas",
    description:
      "Cree y administre múltiples áreas de servicio con reglas de prioridad y flujos personalizados.",
    icon: "ph:brain-duotone",
    image: featureImage2,
  },
  {
    title: "Emisión Multicanal",
    description:
      "Generación de tickets físicos, turnos por código QR y visualización en pantallas multimedia (Hubs).",
    icon: "ph:ticket-duotone",
    image: featureImage3,
  },
  {
    title: "Estación del Agente",
    description:
      "Interfaz optimizada para que su personal gestione llamadas y atención con la máxima eficiencia.",
    icon: "ph:desktop-duotone",
    image: featureImage4,
  },
  {
    title: "Análisis y Reportes",
    description:
      "Obtenga métricas detalladas sobre tiempos de espera, volumen de atención y desempeño del equipo.",
    icon: "ph:presentation-chart-duotone",
    image: featureImage5,
  },
  {
    title: "Flujos Únicos",
    description:
      "Configure recorridos multi-etapa donde el usuario mantiene un único turno para múltiples departamentos.",
    icon: "ph:arrows-merge-duotone",
    image: featureImage6,
  },
];

// --- Texto Principal ---
const mainTitle = "Todo lo que necesitas para controlar tu flujo de atención";
const mainSubtitle =
  "Nuestras herramientas combinan la robustez empresarial con una interfaz intuitiva. Digitalice rápidamente su servicio y asegure una experiencia de cliente de alto nivel.";
// -----------------------
---

<section
  class="py-32 bg-gradient-to-b from-white to-payflo-gray relative overflow-hidden"
>
  <div class="absolute inset-0 opacity-5 parallax" data-speed="0.1">
    <div
      class="absolute inset-0 bg-repeat"
      style="background-image: url('/grid-pattern.svg');"
    >
    </div>
  </div>

  <div class="container-custom relative">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="animate-on-scroll delay-0 text-3xl md:text-4xl font-bold">
        {mainTitle}
      </h2>
      <p class="animate-on-scroll delay-1 mt-4 text-xl text-gray-600 leading-relaxed max-w-2xl mx-auto">
        {mainSubtitle}
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 justify-center">
      {
        features.map((feature, index) => (
          <div
            class={`feature-card glass-card animate-on-scroll delay-${index + 2} group`}
          >
            <h3 class="text-xl font-semibold transition-colors duration-300 group-hover:text-payflo-purple">
              {feature.title}
            </h3>
            <p class="mt-3 text-gray-600">{feature.description}</p>
            <div class="mt-6 hover-zoom rounded-lg overflow-hidden">
              <Image
                src={feature.image}
                alt={feature.title}
                class="w-full h-auto rounded-lg transition-all duration-500"
              />
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import VanillaTilt from "vanilla-tilt";

  document.addEventListener("astro:page-load", () => {
    const cards = document.querySelectorAll(".feature-card");
    VanillaTilt.init(Array.from(cards) as HTMLElement[], {
      max: 5,
      speed: 400,
      glare: true,
      "max-glare": 0.2,
    });
  });
</script>
