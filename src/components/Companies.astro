---
import { Icon } from "astro-icon/components";

const companiesData = [
  {
    id: 1,
    name: "Centro Médico Primed Bonao",
    problem:
      "Largas filas de espera y falta de trazabilidad en la atención de pacientes en las áreas de imágenes diagnósticas y laboratorio.",
  },
  {
    id: 2,
    name: "TechFlow",
    problem:
      "Falta de eficiencia en el soporte técnico y demoras en la asignación de tickets de servicio para los clientes corporativos.",
  },
  {
    id: 3,
    name: "Quantum",
    problem:
      "Saturación en las ventanillas de servicio al cliente y pérdida de datos en la transferencia de turnos entre departamentos.",
  },
  {
    id: 4,
    name: "Innovate",
    problem:
      "Dificultad para medir el rendimiento del personal de atención y largos tiempos muertos entre citas programadas.",
  },
  {
    id: 5,
    name: "PlatformX",
    problem:
      "Experiencia de usuario deficiente durante la incorporación de nuevos clientes por falta de un flujo de atención estructurado.",
  },
  {
    id: 6,
    name: "SyncWave",
    problem:
      "Desorganización en las salas de espera físicas y dificultad para coordinar la atención omnicanal en tiempo real.",
  },
];
---

<section class="py-24 bg-white relative overflow-hidden">
  <div class="container-custom relative z-10">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll mb-16">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-payflo-dark leading-[1.1]">
        Instituciones que <span class="text-transparent bg-clip-text bg-gradient-to-r from-step-1 via-step-2 to-step-3">revolucionan su atención</span>
      </h2>
    </div>

    <div
      class="relative w-full overflow-hidden flex py-4 group animate-on-scroll delay-1"
    >
      <!-- Fade edges for depth -->
      <div
        class="absolute left-0 top-0 bottom-0 w-24 md:w-40 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"
      >
      </div>
      <div
        class="absolute right-0 top-0 bottom-0 w-24 md:w-40 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"
      >
      </div>

      <!-- Scrolling Track -->
      <div
        class="flex animate-marquee-logos group-hover:[animation-play-state:paused] items-center w-max"
      >
        <!-- First Set -->
        <div class="flex items-center gap-10 md:gap-16 pr-10 md:pr-16 shrink-0">
          {
            [...Array(10)]
              .flatMap(() => [1, 2, 3, 4, 5, 6])
              .map((num) => (
                <img
                  src={`/partner-logo-${num}.svg`}
                  alt={`Partner ${num}`}
                  data-company-id={num}
                  class="company-logo-btn h-16 md:h-24 lg:h-28 w-auto object-contain transition-all duration-500 hover:scale-110 cursor-pointer"
                />
              ))
          }
        </div>

        <!-- Second Set (Duplicate for loop) -->
        <div class="flex items-center gap-10 md:gap-16 pr-10 md:pr-16 shrink-0">
          {
            [...Array(10)]
              .flatMap(() => [1, 2, 3, 4, 5, 6])
              .map((num) => (
                <img
                  src={`/partner-logo-${num}.svg`}
                  alt={`Partner ${num}`}
                  data-company-id={num}
                  class="company-logo-btn h-16 md:h-24 lg:h-28 w-auto object-contain transition-all duration-500 hover:scale-110 cursor-pointer"
                />
              ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- JSON Data for Client -->
  <script
    type="application/json"
    id="companies-data-json"
    set:html={JSON.stringify(companiesData)}
  />

  <!-- Modal -->
  <div
    id="company-modal"
    class="fixed inset-0 z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300"
  >
    <!-- Backdrop -->
    <div
      id="company-modal-backdrop"
      class="absolute inset-0 bg-gray-900/40 backdrop-blur-sm"
    >
    </div>

    <!-- Modal Content -->
    <div
      class="relative bg-white rounded-3xl shadow-2xl w-[90%] max-w-lg p-8 md:p-10 transform scale-95 opacity-0 transition-all duration-300 z-10 border border-gray-100"
    >
      <button
        id="company-modal-close"
        class="absolute top-6 right-6 text-gray-400 hover:text-gray-700 transition-colors bg-gray-50 hover:bg-gray-100 p-2 rounded-full"
      >
        <Icon name="ph:x-bold" class="w-5 h-5" />
      </button>

      <div class="flex items-center gap-6 mb-8">
        <div
          class="w-20 h-20 md:w-24 md:h-24 rounded-2xl bg-gray-50 flex items-center justify-center border border-gray-100 shadow-sm p-4"
        >
          <img
            id="modal-company-logo"
            src=""
            alt="Company Logo"
            class="w-full h-full object-contain"
          />
        </div>
        <div>
          <h3
            id="modal-company-name"
            class="text-xl md:text-2xl font-bold text-payflo-dark mb-1"
          >
            Nombre Empresa
          </h3>
          <span
            class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-payflo-purple/10 text-payflo-purple text-xs font-semibold uppercase tracking-wider"
          >
            Caso de Éxito
          </span>
        </div>
      </div>

      <div class="space-y-6">
        <div>
          <h4
            class="text-sm font-bold text-gray-900 uppercase tracking-wider mb-3 flex items-center gap-2"
          >
            <Icon name="ph:target-duotone" class="w-5 h-5 text-payflo-purple" />
            Problema Solucionado
          </h4>
          <p
            id="modal-company-problem"
            class="text-gray-600 text-sm leading-relaxed bg-gray-50 p-4 rounded-2xl border border-gray-100"
          >
            Descripción del problema...
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes marquee-logos {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-marquee-logos {
    animation: marquee-logos 38s linear infinite reverse;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("company-modal");
    const modalBackdrop = document.getElementById("company-modal-backdrop");
    const closeBtn = document.getElementById("company-modal-close");
    const trackContainer = document.querySelector(".animate-marquee-logos");

    const companyName = document.getElementById("modal-company-name");
    const companyProblem = document.getElementById("modal-company-problem");
    const companyLogo = document.getElementById("modal-company-logo");

    const jsonDataEl = document.getElementById("companies-data-json");
    if (!jsonDataEl) return;

    const companiesData = JSON.parse(jsonDataEl.textContent);

    function openModal(id) {
      const data = companiesData.find((c) => c.id === id);
      if (!data) return;

      companyName.textContent = data.name;
      companyProblem.textContent = data.problem;
      companyLogo.src = `/partner-logo-${id}.svg`;

      modal.classList.remove("hidden");

      // Pause animation
      if (trackContainer) {
        trackContainer.style.animationPlayState = "paused";
      }

      setTimeout(() => {
        modal.classList.remove("opacity-0");
        modal
          .querySelector(".transform")
          .classList.remove("scale-95", "opacity-0");
      }, 10);
    }

    function closeModal() {
      modal.classList.add("opacity-0");
      modal.querySelector(".transform").classList.add("scale-95", "opacity-0");
      setTimeout(() => {
        modal.classList.add("hidden");
        // Resume animation
        if (trackContainer) {
          trackContainer.style.animationPlayState = "running";
        }
      }, 300);
    }

    const logos = document.querySelectorAll(".company-logo-btn");
    logos.forEach((logo) => {
      logo.addEventListener("click", () => {
        const id = parseInt(logo.getAttribute("data-company-id"));
        openModal(id);
      });
    });

    if (closeBtn) closeBtn.addEventListener("click", closeModal);
    if (modalBackdrop) modalBackdrop.addEventListener("click", closeModal);
  });
</script>
