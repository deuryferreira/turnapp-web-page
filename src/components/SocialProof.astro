---
import { Icon } from "astro-icon/components";

// Componente de Prueba Social Dinámica (Social Proof Toast)
---

<div
  id="social-proof-toast"
  class="fixed bottom-8 left-8 z-[100] transform translate-y-20 opacity-0 transition-all duration-700 ease-out pointer-events-none md:pointer-events-auto"
>
  <div class="bg-white/90 backdrop-blur-xl p-5 rounded-2xl flex items-start gap-4 max-w-sm shadow-2xl border border-white">
    <div class="h-10 w-10 mt-1 rounded-full bg-gradient-to-br from-green-400 to-emerald-600 flex-shrink-0 flex items-center justify-center text-white shadow-lg">
      <Icon name="ph:check-circle-duotone" class="w-6 h-6" />
    </div>
    <div>
      <p class="text-sm font-bold text-gray-900 leading-tight" id="sp-location">Caso de Éxito</p>
      <p class="text-sm text-gray-600 mt-1.5 leading-relaxed" id="sp-detail">Cargando...</p>
      <p class="text-[10px] text-green-600 font-bold mt-2 uppercase tracking-widest flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
        <span id="sp-time">Verificado</span>
      </p>
    </div>
    
    <button id="sp-close" class="absolute top-3 right-3 text-gray-400 hover:text-gray-600 transition-colors">
      <Icon name="ph:x-circle-duotone" class="w-5 h-5" />
    </button>
  </div>
</div>

<script>
  const data = [
    { 
      location: "Clínica San Juan", 
      detail: "Redujo el tiempo de espera de sus pacientes en un 45% usando las colas inteligentes de TurnApp.", 
      time: "Este mes" 
    },
    { 
      location: "Banco Nacional", 
      detail: "Aumentó la satisfacción del cliente al 98% implementando emisión de turnos por QR.", 
      time: "Reciente" 
    },
    { 
      location: "Centro de Servicios", 
      detail: "Procesó 500+ turnos diarios sin aglomeraciones gracias a las pantallas HUB.", 
      time: "Hace 2 meses" 
    },
    { 
      location: "Hospital Central", 
      detail: "Organizó 4 departamentos médicos con un flujo de atención unificado y transparente.", 
      time: "Este trimestre" 
    },
    { 
      location: "Agencia de Envíos", 
      detail: "Optimizó la estación de sus 12 agentes, reduciendo el tiempo por transacción a la mitad.", 
      time: "Este año" 
    }
  ];

  let currentIdx = 0;
  let isClosed = false;

  function showToast() {
    if (isClosed) return;
    
    const toast = document.getElementById('social-proof-toast');
    const locationEl = document.getElementById('sp-location');
    const detailEl = document.getElementById('sp-detail');
    const timeEl = document.getElementById('sp-time');

    if (!toast || !locationEl || !detailEl || !timeEl) return;

    // Aleatorizar un poco para que se sienta más orgánico, o seguir en orden
    const item = data[currentIdx];
    locationEl.textContent = `Éxito: ${item.location}`;
    detailEl.textContent = item.detail;
    timeEl.textContent = item.time;

    // Mostrar
    toast.classList.remove('translate-y-20', 'opacity-0');
    toast.classList.add('translate-y-0', 'opacity-100');

    // Ocultar después de 8 segundos
    setTimeout(() => {
      toast.classList.add('translate-y-20', 'opacity-0');
      toast.classList.remove('translate-y-0', 'opacity-100');
      
      // Siguiente ítem
      currentIdx = (currentIdx + 1) % data.length;
    }, 8000);
  }

  document.addEventListener("DOMContentLoaded", () => {
    // Cerrar permanentemente si el usuario hace clic en la X
    const closeBtn = document.getElementById('sp-close');
    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        isClosed = true;
        const toast = document.getElementById('social-proof-toast');
        if (toast) {
          toast.classList.add('translate-y-20', 'opacity-0');
          toast.classList.remove('translate-y-0', 'opacity-100');
        }
      });
    }

    // Iniciar después de 6 segundos de carga
    setTimeout(() => {
      showToast();
      // Repetir cada 35 segundos
      setInterval(showToast, 35000);
    }, 6000);
  });
</script>
