---
const steps = [
  {
    number: "01",
    title: "Análisis y Definición del Flujo",
    description:
      "Nuestro equipo se reúne con usted para entender sus áreas de servicio, sus reglas de atención (PEPS) y diseñar el flujo óptimo para su institución. Evaluamos la carga operativa para asegurar un enrutamiento perfecto.",
  },
  {
    number: "02",
    title: "Implementación y Personalización",
    description:
      "Configuramos toda la plataforma TurnApp: desde la lógica de los llamados por área hasta la adaptación visual de las pantallas HUB con su línea gráfica, logrando una inmersión de marca total.",
  },
  {
    number: "03",
    title: "Activación y Soporte Continuo",
    description:
      "Realizamos la puesta en marcha, capacitamos a su personal para el uso inmediato y aseguramos el monitoreo y soporte en tiempo real para una operación fluida desde el primer día.",
  },
];

// --- Texto Principal ---
const mainTitle = "Ponemos a Trabajar a TurnApp en Tres Pasos Rápidos";
const mainSubtitle =
  "Olvídese de configuraciones complejas. Nuestro equipo experto se encarga de la implementación de principio a fin, garantizando una activación sin fricciones.";
// -----------------------
---

<section class="py-32 bg-white relative overflow-hidden">
  <div class="container-custom relative z-10">
    <div class="max-w-4xl animate-on-scroll delay-0 mb-20">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-payflo-dark leading-[1.1]">
        Ponemos a trabajar a TurnApp en <span class="text-transparent bg-clip-text bg-gradient-to-r from-payflo-purple to-payflo-blue">tres pasos</span> rápidos.
      </h2>
      <p class="mt-6 text-xl md:text-2xl text-gray-500 font-light max-w-2xl leading-relaxed">
        Olvídese de configuraciones complejas. Nuestro equipo experto se encarga de la implementación de principio a fin.
      </p>
    </div>

    <div class="relative max-w-5xl mx-auto">
      <!-- Vertical line connector -->
      <div class="hidden md:block absolute left-[3.5rem] top-8 bottom-8 w-px bg-gradient-to-b from-payflo-purple/50 via-payflo-blue/30 to-transparent z-0"></div>

      <div class="space-y-16 md:space-y-24">
        {
          steps.map((step, index) => (
            <div class="relative z-10 flex flex-col md:flex-row gap-8 md:gap-16 items-start group animate-on-scroll" style={`animation-delay: ${(index * 0.2)}s`}>
              
              <!-- Number Indicator -->
              <div class="flex-shrink-0 relative">
                <div class="w-20 h-20 md:w-28 md:h-28 rounded-full bg-white shadow-[0_10px_40px_-10px_rgba(0,0,0,0.1)] border border-gray-100 flex items-center justify-center relative z-10 group-hover:scale-110 transition-transform duration-500 ease-out">
                  <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-payflo-purple to-payflo-blue opacity-0 group-hover:opacity-10 transition-opacity duration-500"></div>
                  <span class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-br from-gray-800 to-gray-400 group-hover:from-payflo-purple group-hover:to-payflo-blue transition-colors duration-500">
                    {step.number}
                  </span>
                </div>
                <!-- Massive Background Number -->
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[150px] md:text-[250px] font-black text-gray-50/80 -z-10 select-none group-hover:text-gray-100 transition-colors duration-700 pointer-events-none">
                  {step.number}
                </div>
              </div>

              <!-- Content -->
              <div class="pt-4 md:pt-8 flex-grow">
                <h3 class="text-2xl md:text-3xl font-semibold text-payflo-dark group-hover:text-payflo-purple transition-colors duration-300">
                  {step.title}
                </h3>
                <p class="mt-4 text-lg md:text-xl text-gray-500 font-light leading-relaxed max-w-2xl">
                  {step.description}
                </p>
              </div>
              
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
