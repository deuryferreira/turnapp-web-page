---
const steps = [
  {
    number: "01",
    title: "Análisis y Definición del Flujo",
    description:
      "Nuestro equipo se reúne con usted para entender sus áreas de servicio, sus reglas de atención (PEPS) y diseñar el flujo óptimo para su institución. Evaluamos la carga operativa para asegurar un enrutamiento perfecto.",
    textHover: "group-hover:text-step-1",
    bgHover: "group-hover:bg-step-1/10",
    gradientFromHover: "group-hover:from-step-1/20",
    borderHover: "group-hover:border-step-1/50",
  },
  {
    number: "02",
    title: "Implementación y Personalización",
    description:
      "Configuramos toda la plataforma TurnApp: desde la lógica de los llamados por área hasta la adaptación visual de las pantallas HUB con su línea gráfica, logrando una inmersión de marca total.",
    textHover: "group-hover:text-step-2",
    bgHover: "group-hover:bg-step-2/10",
    gradientFromHover: "group-hover:from-step-2/20",
    borderHover: "group-hover:border-step-2/50",
  },
  {
    number: "03",
    title: "Activación y Soporte Continuo",
    description:
      "Realizamos la puesta en marcha, capacitamos a su personal para el uso inmediato y aseguramos el monitoreo y soporte en tiempo real para una operación fluida desde el primer día.",
    textHover: "group-hover:text-step-3",
    bgHover: "group-hover:bg-step-3/10",
    gradientFromHover: "group-hover:from-step-3/20",
    borderHover: "group-hover:border-step-3/50",
  },
];

// --- Texto Principal ---
const mainTitle = "Ponemos a Trabajar a TurnApp en Tres Pasos Rápidos";
const mainSubtitle =
  "Olvídese de configuraciones complejas. Nuestro equipo experto se encarga de la implementación de principio a fin, garantizando una activación sin fricciones.";
// -----------------------
---

<section class="py-32 bg-[#F8FAFC] relative overflow-hidden">
  <div class="container-custom relative z-10">
    <div class="max-w-4xl animate-on-scroll delay-0 mb-20">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-payflo-dark leading-[1.1]">
        Ponemos a trabajar a TurnApp en <span class="text-transparent bg-clip-text bg-gradient-to-r from-step-1 via-step-2 to-step-3">tres pasos</span> rápidos.
      </h2>
      <p class="mt-6 text-xl md:text-2xl text-gray-500 font-light max-w-2xl leading-relaxed">
        Olvídese de configuraciones complejas. Nuestro equipo experto se encarga de la implementación de principio a fin.
      </p>
    </div>

    <div class="relative max-w-5xl mx-auto">
      <!-- Vertical line connector -->
      <div class="hidden md:block absolute left-[3.5rem] top-8 bottom-8 w-[2px] bg-gradient-to-b from-step-1 via-step-2 to-step-3 opacity-30 z-0"></div>

      <div class="space-y-16 md:space-y-24">
        {
          steps.map((step, index) => (
            <div class="relative z-10 flex flex-col md:flex-row gap-8 md:gap-16 items-start group animate-on-scroll" style={`animation-delay: ${(index * 0.2)}s`}>
              
              <!-- Number Indicator -->
              <div class="flex-shrink-0 relative">
                <div class={`w-20 h-20 md:w-28 md:h-28 rounded-full bg-white shadow-[0_10px_40px_-10px_rgba(0,0,0,0.05)] border-2 border-gray-100 flex items-center justify-center relative z-10 group-hover:scale-110 transition-all duration-500 ease-out overflow-hidden ${step.borderHover}`}>
                  <div class={`absolute inset-0 bg-gradient-to-tr ${step.gradientFromHover} to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500`}></div>
                  <span class={`text-3xl md:text-4xl font-bold text-gray-400 transition-colors duration-500 relative z-10 ${step.textHover}`}>
                    {step.number}
                  </span>
                </div>
                <!-- Massive Background Number -->
                <div class={`absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-[150px] md:text-[250px] font-black text-gray-200/50 -z-10 select-none transition-colors duration-700 pointer-events-none ${step.textHover} group-hover:opacity-10`}>
                  {step.number}
                </div>
              </div>

              <!-- Content -->
              <div class={`pt-4 md:pt-8 flex-grow p-6 md:p-8 rounded-3xl transition-all duration-500 border border-transparent ${step.bgHover} group-hover:border-white/50 group-hover:shadow-lg backdrop-blur-sm -ml-6 md:-ml-8 mt-[-1.5rem] md:mt-[-2rem]`}>
                <h3 class={`text-2xl md:text-3xl font-semibold text-payflo-dark transition-colors duration-300 ${step.textHover}`}>
                  {step.title}
                </h3>
                <p class="mt-4 text-lg md:text-xl text-gray-500 font-light leading-relaxed max-w-2xl relative z-20 transition-colors duration-300 group-hover:text-gray-700">
                  {step.description}
                </p>
              </div>
              
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
