---
import { Icon } from "astro-icon/components";

const testimonials = [
  {
    name: "Dr. Carlos Mendoza",
    role: "Director Médico",
    company: "Hospital Central",
    content: "TurnApp redujo nuestros tiempos de espera en salas un 40%. La eficiencia operativa ha sido increíble y los pacientes lo notan de inmediato.",
    avatarBg: "from-blue-400 to-payflo-purple",
    initials: "CM"
  },
  {
    name: "Lucía Fernández",
    role: "Gte. de Experiencia del Paciente",
    company: "Clínica San José",
    content: "La inmersión de marca en las pantallas HUB cambió por completo la percepción de nuestros pacientes. Sienten que están en un lugar premium.",
    avatarBg: "from-teal-400 to-emerald-500",
    initials: "LF"
  },
  {
    name: "Roberto Pineda",
    role: "Jefe de Operaciones",
    company: "Centro de Especialidades",
    content: "Desde el día 1 vimos el impacto. La capacitación fue rapidísima y el equipo de TurnApp nos dio soporte total sin interrupciones.",
    avatarBg: "from-orange-400 to-pink-500",
    initials: "RP"
  },
  {
    name: "María Gómez",
    role: "Directora de Tecnología",
    company: "Red Salud Integral",
    content: "La flexibilidad de la plataforma nos permitió adaptar reglas de negocio muy complejas (PEPS y Prioridades) sin tener que escribir código extra.",
    avatarBg: "from-indigo-400 to-blue-600",
    initials: "MG"
  },
  {
    name: "Andrés Torres",
    role: "Coordinador General",
    company: "Laboratorios Vida",
    content: "El control absoluto sobre los turnos nos permitió optimizar la carga de trabajo de los técnicos. Nunca más tuvimos salas de espera abarrotadas.",
    avatarBg: "from-purple-400 to-indigo-500",
    initials: "AT"
  }
];

---

<section class="py-24 bg-[#F8FAFC] relative overflow-hidden">
  <div class="container-custom">
    <div class="text-center mb-12 animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-bold text-payflo-dark tracking-tight">
        Líderes que confían en <span class="text-payflo-purple">TurnApp</span>
      </h2>
    </div>
  </div>

  <!-- Marquee Container -->
  <div class="relative w-full overflow-hidden flex py-4 group">
    
    <!-- Fade edges for depth -->
    <div class="absolute left-0 top-0 bottom-0 w-16 md:w-40 bg-gradient-to-r from-[#F8FAFC] to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-16 md:w-40 bg-gradient-to-l from-[#F8FAFC] to-transparent z-10 pointer-events-none"></div>

    <!-- Scrolling Track -->
    <div class="flex animate-marquee group-hover:[animation-play-state:paused] gap-6 px-3 w-max">
      
      <!-- First Set -->
      <div class="flex gap-6 shrink-0">
        {testimonials.map((testimonial) => (
          <div class="w-[280px] md:w-[340px] flex-shrink-0 bg-white/80 backdrop-blur-sm border border-gray-200/60 rounded-2xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgb(0,0,0,0.06)] hover:bg-white transition-all duration-300 hover:-translate-y-1 whitespace-normal">
            <!-- Rating -->
            <div class="flex gap-0.5 mb-4 text-yellow-400">
              <Icon name="ph:star-duotone" class="w-4 h-4" />
              <Icon name="ph:star-duotone" class="w-4 h-4" />
              <Icon name="ph:star-duotone" class="w-4 h-4" />
              <Icon name="ph:star-duotone" class="w-4 h-4" />
              <Icon name="ph:star-duotone" class="w-4 h-4" />
            </div>
            
            <!-- Content -->
            <p class="text-gray-600 text-sm leading-relaxed mb-6 italic">
              "{testimonial.content}"
            </p>
            
            <!-- Author Profile -->
            <div class="flex items-center gap-3 mt-auto">
              <div class={`w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm bg-gradient-to-br ${testimonial.avatarBg} shadow-inner`}>
                {testimonial.initials}
              </div>
              <div>
                <h4 class="font-bold text-sm text-payflo-dark">{testimonial.name}</h4>
                <p class="text-xs text-gray-500 font-medium">{testimonial.role}</p>
                <p class="text-[10px] text-payflo-purple mt-0.5 uppercase tracking-wider">{testimonial.company}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Second Set (Duplicate for infinite loop) -->
      <div class="flex gap-6 shrink-0">
        {testimonials.map((testimonial) => (
          <div class="w-[280px] md:w-[340px] flex-shrink-0 bg-white/80 backdrop-blur-sm border border-gray-200/60 rounded-2xl p-6 shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-[0_8px_30px_rgb(0,0,0,0.06)] hover:bg-white transition-all duration-300 hover:-translate-y-1 whitespace-normal">
            <!-- Rating -->
            <div class="flex gap-0.5 mb-4 text-yellow-400">
              <Icon name="ph:star-duotone" class="w-4 h-4" />
              <Icon name="ph:star-duotone" class="w-4 h-4" />
              <Icon name="ph:star-duotone" class="w-4 h-4" />
              <Icon name="ph:star-duotone" class="w-4 h-4" />
              <Icon name="ph:star-duotone" class="w-4 h-4" />
            </div>
            
            <!-- Content -->
            <p class="text-gray-600 text-sm leading-relaxed mb-6 italic">
              "{testimonial.content}"
            </p>
            
            <!-- Author Profile -->
            <div class="flex items-center gap-3 mt-auto">
              <div class={`w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm bg-gradient-to-br ${testimonial.avatarBg} shadow-inner`}>
                {testimonial.initials}
              </div>
              <div>
                <h4 class="font-bold text-sm text-payflo-dark">{testimonial.name}</h4>
                <p class="text-xs text-gray-500 font-medium">{testimonial.role}</p>
                <p class="text-[10px] text-payflo-purple mt-0.5 uppercase tracking-wider">{testimonial.company}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  /* Seamless Marquee Animation */
  @keyframes marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      /* Scroll left by exactly half the total width of the track plus half the gap (1.5rem / 2) */
      transform: translateX(calc(-50% - 0.75rem));
    }
  }

  .animate-marquee {
    animation: marquee 40s linear infinite;
  }
</style>
