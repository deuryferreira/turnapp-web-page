---
const testimonials = [
  {
    quote: "La implementación de TurnApp fue clave para terminar con el caos en la recepción. Ahora tenemos un flujo de atención ordenado y medible.",
    author: "Elena Ramírez",
    role: "Gerente de Operaciones",
    avatar: "/testimonial-avatar-1.jpg",
  },
  {
    quote: "El equipo nos guió en cada paso. Pudimos personalizar las pantallas con nuestra marca en muy poco tiempo. El soporte ha sido excepcional.",
    author: "Javier Soto",
    role: "Director de TI",
    avatar: "/testimonial-avatar-2.jpg",
  },
  {
    quote: "Nuestros tiempos de espera se redujeron en un 30% en el primer mes. La claridad que ofrecen las pantallas es un cambio radical.",
    author: "Lorena Guzmán",
    role: "Jefa de Servicio",
    avatar: "/testimonial-avatar-3.jpg",
  },
  {
    quote: "Desde que instalamos los kioskos de autoservicio, la fila física desapareció. Los pacientes esperan sentados tranquilos viendo el HUB.",
    author: "Dr. Carlos Méndez",
    role: "Director Médico",
    avatar: "/testimonial-avatar-4.jpg",
  }
];

// Cuadruplicamos el array para asegurar el efecto de scroll infinito suave sin saltos
const repeatedTestimonials = [...testimonials, ...testimonials, ...testimonials, ...testimonials];
---

<section class="py-20 bg-gray-50 overflow-hidden relative">
  <div class="container-custom relative z-10 mb-12">
    <div class="max-w-4xl mx-auto text-center animate-on-scroll mb-8">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-payflo-dark leading-[1.1]">
        Líderes que <span class="text-transparent bg-clip-text bg-gradient-to-r from-step-1 via-step-2 to-step-3">confían en nosotros</span>
      </h2>
    </div>
  </div>

  <div class="relative w-full overflow-hidden flex py-4 group">
    <!-- Fade edges for depth -->
    <div class="absolute left-0 top-0 bottom-0 w-24 md:w-40 bg-gradient-to-r from-gray-50 to-transparent z-10 pointer-events-none"></div>
    <div class="absolute right-0 top-0 bottom-0 w-24 md:w-40 bg-gradient-to-l from-gray-50 to-transparent z-10 pointer-events-none"></div>

    <!-- Scrolling Track -->
    <div class="flex animate-marquee-testimonials group-hover:[animation-play-state:paused] items-center w-max">
      
      <div class="flex gap-6 md:gap-8 px-4">
        {repeatedTestimonials.map((testimonial) => (
          <div class="bg-white p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 w-[300px] md:w-[350px] flex-shrink-0 transition-transform duration-300 hover:-translate-y-1">
            <p class="text-gray-600 text-sm md:text-base leading-relaxed mb-6 italic">
              "{testimonial.quote}"
            </p>
            <div class="flex items-center gap-3 opacity-80">
              <div class="w-10 h-10 rounded-full bg-gray-200 overflow-hidden flex-shrink-0">
                <img src={testimonial.avatar} alt={testimonial.author} class="w-full h-full object-cover" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0iI2U1ZTdlYiI+PHBhdGggZD0iTTI0IDIwaC0yNHYtNGMwLTIuMiAxLjgtNCA0LTRoMTZjMi4yIDAgNCAxLjggNCA0djR6TTEyIDEzYzMuMyAwIDYtMi43IDYtNnMtMi43LTYtNi02LTYgMi43LTYgNnMyLjcgNiA2IDZ6Ii8+PC9zdmc+'" />
              </div>
              <div>
                <h4 class="font-semibold text-gray-900 text-sm">{testimonial.author}</h4>
                <p class="text-xs text-gray-500">{testimonial.role}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes marquee-testimonials {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-marquee-testimonials {
    animation: marquee-testimonials 120s linear infinite;
  }
</style>
