---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import productImage from "../assets/present_sin_slogan.png";
import { Icon } from "astro-icon/components";
import CTASection from "../components/CTASection.astro";

// Import images for Bento Grid
import featureImage1 from "../assets/features/ft1.webp";
import featureImage2 from "../assets/features/ft2.webp";
import featureImage3 from "../assets/features/ft3.webp";
import featureImage4 from "../assets/features/ft4.webp";
import featureImage5 from "../assets/features/ft5.webp";
import featureImage6 from "../assets/features/ft6.webp";

const features = [
  {
    title: "Monitoreo en Tiempo Real",
    description:
      "Dashboard centralizado para visualizar al instante el estado de todas las colas y módulos.",
    icon: "ph:monitor-duotone",
    image: featureImage1,
    spanClasses: "md:col-span-2 md:row-span-2",
    imageStyle: "object-cover object-left-top",
  },
  {
    title: "Gestión Inteligente",
    description:
      "Múltiples áreas de servicio con reglas de prioridad avanzadas.",
    icon: "ph:brain-duotone",
    image: featureImage2,
    spanClasses: "md:col-span-1 md:row-span-1",
    imageStyle: "object-contain object-bottom scale-110 translate-y-4",
  },
  {
    title: "Emisión Multicanal",
    description:
      "Tickets impresos y turnos QR.",
    icon: "ph:ticket-duotone",
    image: featureImage3,
    spanClasses: "md:col-span-1 md:row-span-1",
    imageStyle: "object-contain object-center scale-110",
  },
  {
    title: "Estación del Agente",
    description:
      "Interfaz intuitiva para gestionar llamadas con máxima eficiencia.",
    icon: "ph:desktop-duotone",
    image: featureImage4,
    spanClasses: "md:col-span-2 md:row-span-1",
    imageStyle: "object-cover object-top",
  },
  {
    title: "Análisis y Reportes",
    description:
      "Métricas detalladas de tiempos de espera para la mejora continua.",
    icon: "ph:presentation-chart-duotone",
    image: featureImage5,
    spanClasses: "md:col-span-2 md:row-span-1",
    imageStyle: "object-cover object-center",
  },
  {
    title: "Escalabilidad Total",
    description:
      "Preparada para crecer, desde una sucursal hasta redes nacionales.",
    icon: "ph:trend-up-duotone",
    image: featureImage6,
    spanClasses: "md:col-span-2 md:row-span-1",
    imageStyle: "object-cover object-center",
  },
];
---

<Layout
  title="TurnApp - Producto"
  description="La plataforma de TurnApp digitaliza y optimiza la gestión de filas y la atención al cliente, impulsando la eficiencia operativa."
>
  <!-- HERO CINEMÁTICO -->
  <section class="pt-20 pb-10 md:pt-28 md:pb-16 flex flex-col items-center text-center overflow-hidden relative">
    <div class="absolute inset-0 opacity-5 parallax" data-speed="0.1">
      <div class="absolute inset-0 bg-repeat" style="background-image: url('/grid-pattern.svg');"></div>
    </div>
    
    <div class="container-custom relative z-10 flex flex-col items-center">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-payflo-purple/10 text-payflo-purple font-medium text-sm mb-8 animate-on-scroll delay-0 border border-payflo-purple/20">
        <Icon name="ph:star-duotone" class="w-4 h-4" />
        <span>El futuro del servicio al cliente</span>
      </div>
      
      <h1 class="text-5xl md:text-7xl lg:text-[5.5rem] font-bold tracking-tight max-w-[1000px] leading-[1.05] text-payflo-dark">
        <span class="animate-on-scroll delay-1 inline-block">Una visión</span>
        <span class="animate-on-scroll delay-2 inline-block gradient-text">Moderna</span>
        <span class="animate-on-scroll delay-3 inline-block">para tu gestión.</span>
      </h1>
      
      <p class="mt-8 text-xl md:text-2xl text-gray-500 max-w-2xl animate-on-scroll delay-4 leading-relaxed font-light">
        El sistema fácil de usar y rápido de implementar. Ofrezca infraestructura
        de calidad y características que encantarán a sus usuarios.
      </p>
      
      <div class="mt-12 flex flex-col sm:flex-row gap-4 animate-on-scroll delay-5">
        <a href="/book-demo" class="btn btn-primary btn-magnetic px-8 py-4 text-lg">Agendar llamada</a>
        <a href="/documentation" class="btn btn-secondary btn-magnetic px-8 py-4 text-lg border border-gray-300">Documentación</a>
        <a href="/contact" class="btn btn-secondary btn-magnetic px-8 py-4 text-lg border border-gray-300 opacity-80 hover:opacity-100">Contacto</a>
      </div>
    </div>

    <!-- PRODUCT SHOWCASE (GLASSMORPHISM) -->
    <div class="mt-20 w-full max-w-6xl mx-auto px-4 md:px-8 animate-on-scroll delay-6 relative z-10">
      <div class="relative rounded-2xl md:rounded-[2rem] bg-gradient-to-b from-gray-50 to-gray-200/50 p-2 md:p-4 shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] border border-white/50 backdrop-blur-xl">
        <div class="absolute inset-0 bg-gradient-to-tr from-payflo-purple/20 to-payflo-blue/20 blur-3xl opacity-30 -z-10 rounded-full scale-90"></div>
        <div class="rounded-xl md:rounded-[1.5rem] overflow-hidden border border-gray-100/50 shadow-inner bg-white">
          <Image
            src={productImage}
            alt="Panel de Control del Producto TurnApp"
            class="w-full h-auto hover:scale-[1.02] transition-transform duration-1000 ease-out"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- BENTO GRID SECTION (DARK MODE) -->
  <section class="py-24 bg-[#0a0a0a] text-white relative overflow-hidden">
    <!-- Glow effects for dark mode -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-payflo-purple rounded-full mix-blend-screen filter blur-[128px] opacity-20"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-payflo-blue rounded-full mix-blend-screen filter blur-[128px] opacity-20"></div>

    <div class="container-custom relative z-10">
      <div class="max-w-3xl animate-on-scroll delay-0">
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight">Características <span class="text-transparent bg-clip-text bg-gradient-to-r from-payflo-purple to-payflo-blue">Clave</span></h2>
        <p class="mt-6 text-xl text-gray-400 font-light max-w-2xl leading-relaxed">
          Todo lo que necesita para ofrecer una solución completa, robusta y eficiente. Diseñado para escalar sin fricción.
        </p>
      </div>

      <!-- BENTO GRID LAYOUT -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 auto-rows-[300px]">
        {features.map((feature, index) => (
          <div 
            class={`relative group rounded-3xl overflow-hidden bg-white/[0.03] border border-white/[0.08] hover:bg-white/[0.06] hover:border-white/[0.2] transition-all duration-500 flex flex-col animate-on-scroll ${feature.spanClasses}`}
            style={`animation-delay: ${(index * 0.1) + 0.2}s`}
          >
            <!-- Content -->
            <div class="p-8 relative z-20 flex-grow flex flex-col justify-between">
              <div>
                <div class="h-12 w-12 rounded-xl bg-white/10 flex items-center justify-center text-white mb-6 backdrop-blur-md border border-white/10 group-hover:bg-payflo-purple/50 transition-colors duration-500">
                  <Icon name={feature.icon} class="h-6 w-6" />
                </div>
                <h3 class="text-2xl font-medium tracking-tight mb-3 text-white/90 group-hover:text-white transition-colors">{feature.title}</h3>
                <p class="text-gray-400 font-light leading-relaxed group-hover:text-gray-300 transition-colors">
                  {feature.description}
                </p>
              </div>
            </div>

            <!-- Bento Image Mask -->
            <div class="absolute inset-0 z-10 opacity-40 group-hover:opacity-70 transition-opacity duration-700 pointer-events-none mt-auto h-full flex items-end justify-center">
              <div class="w-full h-1/2 md:h-2/3 relative mask-image-bento overflow-hidden">
                <Image 
                  src={feature.image} 
                  alt={feature.title} 
                  class={`w-full h-full transform group-hover:scale-105 transition-transform duration-700 ease-out ${feature.imageStyle}`}
                />
              </div>
            </div>
            
            <!-- Glow effect on hover -->
            <div class="absolute inset-0 bg-gradient-to-br from-payflo-purple/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0 pointer-events-none"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  /* Máscara de desvanecimiento para las imágenes del Bento Grid */
  .mask-image-bento {
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 30%, black 100%);
    mask-image: linear-gradient(to bottom, transparent 0%, black 30%, black 100%);
  }
</style>
