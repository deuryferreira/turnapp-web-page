---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import productImage from "../assets/present_sin_slogan.png";
import { Icon } from "astro-icon/components";
import CTASection from "../components/CTASection.astro";

const features = [
  {
    title: "Monitoreo en Tiempo Real",
    description:
      "Dashboard centralizado para visualizar al instante el estado de todas las colas y módulos de atención.",
    icon: "ph:monitor-duotone",
  },
  {
    title: "Gestión Inteligente",
    description:
      "Cree múltiples áreas de servicio con reglas de prioridad avanzadas y flujos de atención personalizados.",
    icon: "ph:brain-duotone",
  },
  {
    title: "Emisión Multicanal",
    description:
      "Soporte para tickets impresos, turnos virtuales vía código QR y visualización en pantallas HUB multimedia.",
    icon: "ph:ticket-duotone",
  },
  {
    title: "Estación del Agente",
    description:
      "Interfaz intuitiva y optimizada para que su personal gestione las llamadas con la máxima eficiencia operativa.",
    icon: "ph:desktop-duotone",
  },
  {
    title: "Análisis y Reportes",
    description:
      "Métricas detalladas de tiempos de espera, volumen de atención y desempeño para la mejora continua.",
    icon: "ph:presentation-chart-duotone",
  },
  {
    title: "Escalabilidad Total",
    description:
      "Solución preparada para crecer con su institución, desde una sucursal hasta redes nacionales complejas.",
    icon: "ph:trend-up-duotone",
  },
];
---

<Layout
  title="TurnApp - Producto"
  description="La plataforma de TurnApp digitaliza y optimiza la gestión de filas y la atención al cliente, impulsando la eficiencia operativa y la satisfacción."
>
  <section class="pt-20 pb-16 md:pt-28 md:pb-24">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="animate-on-scroll">
          <h1 class="text-4xl md:text-5xl font-bold leading-tight">
            Una <span class="gradient-text">Visión Moderna</span> para la Gestión
            de Turnos
          </h1>
          <p class="mt-6 text-xl text-gray-600 max-w-lg">
            El sistema <span class="gradient-text font-semibold">
              TurnApp
            </span> es fácil de usar y rápido de implementar, ofreciendo infraestructura
            de calidad y características que encantarán a sus clientes.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4">
            <a href="/book-demo" class="btn btn-primary">Solicitar Demo</a>
            <a href="/documentation" class="btn btn-secondary"
              >Ver Manuales y Guías</a
            >
          </div>
        </div>

        <div class="animate-on-scroll" style="animation-delay: 0.2s;">
          <div class="relative">
            <div
              class="absolute -inset-1.5 bg-gradient-to-r from-payflo-purple to-payflo-blue rounded-xl opacity-70"
            >
            </div>
            <div class="relative bg-white rounded-xl shadow-xl overflow-hidden">
              <Image
                src={productImage}
                alt="Panel de Control del Producto TurnApp"
                class="w-full h-auto"
                width={700}
                height={500}
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-payflo-gray">
    <div class="container-custom">
      <div class="text-center max-w-3xl mx-auto animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold">Características Clave</h2>
        <p class="mt-4 text-xl text-gray-600">
          Todo lo que necesita para ofrecer una solución completa y eficiente de
          gestión de filas a sus clientes.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          features.map((feature, index) => (
            <div
              key={feature.title}
              class="bg-white rounded-xl p-8 shadow-sm animate-on-scroll"
              style={`animation-delay: ${index * 0.1}s`}
            >
              <div class="h-12 w-12 rounded-lg bg-gradient-to-r from-payflo-purple to-payflo-blue flex items-center justify-center text-white mb-6">
                <Icon name={feature.icon} class="h-6 w-6" />
              </div>
              <h3 class="text-xl font-semibold">{feature.title}</h3>
              <p class="mt-3 text-gray-600">{feature.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTASection />
</Layout>
