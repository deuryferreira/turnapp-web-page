{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/about-us/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/?$",
			"dest": "_render"
		},
		{
			"src": "^/book-demo/?$",
			"dest": "_render"
		},
		{
			"src": "^/careers/?$",
			"dest": "_render"
		},
		{
			"src": "^/case-studies/?$",
			"dest": "_render"
		},
		{
			"src": "^/contact/?$",
			"dest": "_render"
		},
		{
			"src": "^/cookie-policy/?$",
			"dest": "_render"
		},
		{
			"src": "^/documentation/api-reference/?$",
			"dest": "_render"
		},
		{
			"src": "^/documentation/?$",
			"dest": "_render"
		},
		{
			"src": "^/documentation/?$",
			"dest": "_render"
		},
		{
			"src": "^/endesarrollo/?$",
			"dest": "_render"
		},
		{
			"src": "^/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/pricing/?$",
			"dest": "_render"
		},
		{
			"src": "^/privacy-policy/?$",
			"dest": "_render"
		},
		{
			"src": "^/product/?$",
			"dest": "_render"
		},
		{
			"src": "^/solutions/?$",
			"dest": "_render"
		},
		{
			"src": "^/terms-of-use/?$",
			"dest": "_render"
		},
		{
			"src": "^/tutorials/?$",
			"dest": "_render"
		},
		{
			"src": "^/$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}